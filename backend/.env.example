APP_NAME="ERP Enterprise"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_SYSTEM_DOMAIN=systemdomain.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Central Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=erp_system
DB_USERNAME=erp_user
DB_PASSWORD=erp_secret

# Tenancy Configuration
TENANCY_DATABASE_MANAGER=pgsql
TENANCY_CENTRAL_DOMAINS=localhost,api.erp-system.test

BROADCAST_DRIVER=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Passport — Personal Access Client (auto-generated by passport:install)
# Fill after running: php artisan passport:install
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# Passport — Password Grant Client (issues access_token + refresh_token on /api/v1/auth/login)
# Fill after running: php artisan passport:client --password
# For dev/test environments, use the deterministic values below:
PASSPORT_PASSWORD_CLIENT_ID=33
PASSPORT_PASSWORD_CLIENT_SECRET=b3x5ItVFBU46N3oJljIKrbibQLR0CT0LKlzKddG7
